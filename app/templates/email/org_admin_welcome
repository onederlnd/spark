<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Your SparK admin account</title>
</head>
<body style="margin:0; padding:0; background:#1a1f26; font-family:'Helvetica Neue', Helvetica, Arial, sans-serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background:#1a1f26; padding:40px 20px;">
    <tr>
      <td align="center">
        <table width="580" cellpadding="0" cellspacing="0" style="background:#222831; border-radius:16px; overflow:hidden; border:1px solid #2e3744;">

          <!-- Header -->
          <tr>
            <td style="background:linear-gradient(135deg, #5ba3d9, #3ABCB1); padding:32px; text-align:center;">
              <div style="font-size:2rem; margin-bottom:8px;">⚡</div>
              <div style="color:#ffffff; font-size:1.6rem; font-weight:900; letter-spacing:-0.5px;">SparK</div>
              <div style="color:rgba(255,255,255,0.85); font-size:0.9rem; margin-top:4px;">The classroom community platform</div>
            </td>
          </tr>

          <!-- Body -->
          <tr>
            <td style="padding:40px 40px 32px;">
              <h1 style="color:#dce6f0; font-size:1.4rem; font-weight:900; margin:0 0 16px;">Welcome, {{ display_name }}! 👋</h1>
              <p style="color:#7a92aa; font-size:0.95rem; line-height:1.7; margin:0 0 8px;">
                A SparK admin account has been created for you as the administrator of
              </p>
              <p style="color:#3ABCB1; font-size:1.1rem; font-weight:800; margin:0 0 20px;">{{ org_name }}</p>
              <p style="color:#7a92aa; font-size:0.95rem; line-height:1.7; margin:0 0 24px;">
                To get started, set your password using the button below. This link expires in <strong style="color:#dce6f0;">1 hour</strong>.
              </p>

              <!-- Steps -->
              <div style="background:#1a1f26; border-radius:12px; padding:24px; margin-bottom:28px; border:1px solid #2e3744;">
                <table width="100%" cellpadding="0" cellspacing="0">
                  <tr>
                    <td style="padding:10px 0; border-bottom:1px solid #2e3744;">
                      <div style="color:#3ABCB1; font-size:0.75rem; font-weight:800; text-transform:uppercase; letter-spacing:1px; margin-bottom:4px;">Step 1</div>
                      <div style="color:#dce6f0; font-size:0.88rem; font-weight:700;">Set your password</div>
                      <div style="color:#7a92aa; font-size:0.82rem; margin-top:2px;">Click the button below to activate your account</div>
                    </td>
                  </tr>
                  <tr>
                    <td style="padding:10px 0; border-bottom:1px solid #2e3744;">
                      <div style="color:#3ABCB1; font-size:0.75rem; font-weight:800; text-transform:uppercase; letter-spacing:1px; margin-bottom:4px;">Step 2</div>
                      <div style="color:#dce6f0; font-size:0.88rem; font-weight:700;">Add your teachers</div>
                      <div style="color:#7a92aa; font-size:0.82rem; margin-top:2px;">Create teacher accounts for your staff from your admin dashboard</div>
                    </td>
                  </tr>
                  <tr>
                    <td style="padding:10px 0;">
                      <div style="color:#3ABCB1; font-size:0.75rem; font-weight:800; text-transform:uppercase; letter-spacing:1px; margin-bottom:4px;">Step 3</div>
                      <div style="color:#dce6f0; font-size:0.88rem; font-weight:700;">Manage your organization</div>
                      <div style="color:#7a92aa; font-size:0.82rem; margin-top:2px;">Monitor classrooms, approve students, and oversee billing all in one place</div>
                    </td>
                  </tr>
                </table>
              </div>

              <!-- CTA -->
              <table width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td align="center" style="padding-bottom:28px;">
                    <a href="{{ setup_url }}" style="background:linear-gradient(135deg, #5ba3d9, #3ABCB1); color:#ffffff; text-decoration:none; padding:14px 36px; border-radius:50px; font-weight:800; font-size:0.95rem; display:inline-block;">
                      Set My Password
                    </a>
                  </td>
                </tr>
              </table>

              <!-- Fallback URL -->
              <div style="background:#1a1f26; border-radius:10px; padding:16px 20px; margin-bottom:24px; border:1px solid #2e3744;">
                <p style="color:#7a92aa; font-size:0.78rem; margin:0 0 6px;">If the button doesn't work, copy and paste this link into your browser:</p>
                <p style="color:#5ba3d9; font-size:0.78rem; margin:0; word-break:break-all;">{{ setup_url }}</p>
              </div>

              <p style="color:#7a92aa; font-size:0.82rem; line-height:1.7; margin:0;">
                If you weren't expecting this email, you can safely ignore it. Questions? Reply anytime — we're here to help.
              </p>
            </td>
          </tr>

          <!-- Footer -->
          <tr>
            <td style="padding:24px 40px; border-top:1px solid #2e3744; text-align:center;">
              <p style="color:#7a92aa; font-size:0.75rem; margin:0;">
                © 2026 SparK LLC · <a href="https://go-spark.app" style="color:#5ba3d9; text-decoration:none;">go-spark.app</a>
              </p>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>
</html>